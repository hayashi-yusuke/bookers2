<div class="container">
  <div class="row">
    <div class="mx-auto mt-3 col-5">

      <h1>welcome to <i class="fa-solid fa-book"></i><strong>Bookers</strong> !!</h1>
      <p>In <i class="fa-solid fa-book"></i><strong>Bookers</strong>,</p>
      <p>you can share and exchange your opinions , inpressions , and emotions</p>
      <p>about various books!</p>

      <div class="col-10 mx-auto">
        <div class="row mb-3">
          <% if Current.user %>
            <%= link_to "Log in", user_path(Current.user), class: "btn btn-sm w-100", style: "background-color: #17a2b8; color: white;" %>
          <% else %>
            <%= link_to "Log in", new_session_path, class: "btn btn-info btn-sm w-100", style: "background-color: #17a2b8; color: white;" %>
          <% end %>
        </div>
        <div class="row">
          <% if Current.user %>
            <%= link_to "Sign up", user_path(Current.user), class: "btn btn-sm w-100", style: "background-color: #28a745; color: white;" %>
          <% else %>
            <%= link_to "Sign up", new_user_path, class: "btn btn-sm w-100", style: "background-color: #28a745; color: white;" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>