<div class="container mt-3">
  <div class="row">
    <%= render 'users/user_info' %>

    <div class="col-md-8 offset-md-1">
      <h2 style="border-bottom: 1px solid #ccc;">Books</h2>
      <table class="table table-hover">
        <thead style="border-bottom: 2px solid #ccc;">
          <tr>
            <th style="width: 20%;"></th>
            <th style="width: 40%;">Title</th>
            <th style="width: 40%;">Opinion</th>
            <th>コメント</th>
            <th>評価</th>
          </tr>
        </thead>
        <tbody>
          <% @books.each do |book| %>
            <tr>
              <td>
                <%= link_to user_path(book.user) do %>
                  <%= image_tag book.user.profile_image.attached? ? book.user.profile_image : "no_image.jpg", style: "width: 50px; height: 50px; object-fit: cover; border: 1px solid #ccc;" %>
                <% end %>
              </td>
              <td>
                <%= link_to book.title, book_path(book), style: "text-decoration: none;" %>
              </td>
              <td><%= book.body %></td>
              <td><%= book.book_comments.count %></td>
              <td>
                <% if book.reviews.exists? %>
                  <div id="show_raty_<%= book.id %>"
                    data-score="<%= book.reviews.first&.score %>"
                    data-star-on="<%= asset_path('star-on.png') %>"
                    data-star-off="<%= asset_path('star-off.png') %>">
                  </div>
                <% else %>
                  まだ評価がありません
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <!-- 投稿数の統計 -->
      <h2 class="mt-3">投稿数の前日比・前週比</h2>

      <!-- 今日・前日・前日比 -->
      <table class="table table-bordered" style="width: 80%;">
        <thead>
          <tr>
            <th>今日の投稿数</th>
            <th>前日の投稿数</th>
            <th>前日比</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><%= @today_books_count %></td>
            <td><%= @yesterday_books_count %></td>
            <td><%= @today_yesterday_rate %></td>
          </tr>
        </tbody>
      </table>

      <!-- 間を開ける -->
      <div class="mt-4"></div>

      <!-- 今週・先週・先週比 -->
      <table class="table table-bordered" style="width: 80%;">
        <thead>
          <tr>
            <th>今週の投稿数</th>
            <th>先週の投稿数</th>
            <th>先週比</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><%= @this_week_books_count %></td>
            <td><%= @last_week_books_count %></td>
            <td><%= @this_last_week_rate %></td>
          </tr>
        </tbody>
      </table>
      <!-- 過去7日間の投稿数一覧 -->
      <h2 class="mt-3">7日間分の投稿数</h2>
      <table class="table table-bordered" style="width: 80%;">
        <thead>
          <tr>
            <% @weekly_books.each do |data| %>
              <th><%= data[:date] %></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <tr>
            <% @weekly_books.each do |data| %>
              <td><%= data[:count] %></td>
            <% end %>
          </tr>
        </tbody>
      </table>
      <!-- Chart.js グラフ -->
      <h6 class="mt-3 text-center" style="width: 80%;">7日間の投稿数の比較</h6>
      <div style="width: 80%;">
        <canvas id="weeklyChart"></canvas>
      </div>

      <script>
        const labels = <%= raw @weekly_books.map { |data| data[:date] }.to_json %>;
        const counts = <%= raw @weekly_books.map { |data| data[:count] }.to_json %>;

        const ctx = document.getElementById('weeklyChart').getContext('2d');
        new Chart(ctx, {
          type: 'line',
          data: {
            labels: labels,
            datasets: [{
              label: '投稿した本の数',
              data: counts,
              backgroundColor: 'rgba(54, 162, 235, 0.5)',
              borderColor: 'rgba(54, 162, 235, 1)',
              borderWidth: 1,
              tension: 0.4
            }]
          },
          options: {
            scales: {
              y: {
                beginAtZero: true,
                max: 10,        // ← 上限を10にする
                ticks: {
                stepSize: 1  // ← 1刻みにする
                }
              }
            }
          }
        });
      </script>
      <!-- 指定した日の投稿数を表示するエリア -->
      <div class="mt-3">
        <!-- 日付選択フォーム -->
        <%= form_with url: books_on_date_user_path(@user), method: :get, data: { turbo_frame: "books_on_date" } do |f| %>
          <%= f.date_field :date, value: Date.today %>
          <%= f.submit "検索", class: "btn btn-sm btn-primary" %>
        <% end %>
      </div>

      <!-- ここだけ更新される！ -->
      <turbo-frame id="books_on_date">
      </turbo-frame>
    </div>
  </div>
</div>