<div class="container mt-3">
  <div class="row">
    <%= render 'users/user_info' %>

    <div class="col-6 offset-1">
      <h2 style="border-bottom: 1px solid #ccc;">Books</h2>
      <table class="table table-hover">
        <thead style="border-bottom: 2px solid #ccc;">
          <tr>
            <th></th>
            <th>Title</th>
            <th>Opinion</th>
          </tr>
        </thead>
        <tbody>
          <% @books.each do |book| %>
            <tr>
              <td>
                <%= link_to user_path(book.user) do %>
                  <%= image_tag book.user.avatar.attached? ? book.user.avatar : "no_image.jpg", style: "width: 50px; height: 50px; object-fit: cover;" %></td>
                <% end %>
              </td>
              <td>
                <%= link_to book.title, book_path(book), style: "text-decoration: none;" %>
              </td>
              <td><%= book.body %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>