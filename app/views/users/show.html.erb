<div class="container mt-3">
  <div class="row">
    <div class="col-4">
      <h2>User info</h2>

      <img src="NO IMAGE" alt="プロフィール画像">

      <table class="table">
        <tr>
          <td>name</td>
          <td><%= @user.name %></td>
        </tr>
        <tr>
          <td>introduction</td>
          <td><%= @user.introduction %></td>
        </tr>
      </table>

      <%= link_to edit_user_path(@user), class: "btn btn-outline-secondary" do %>
        <i class="fa-solid fa-user-gear"></i>
      <% end %>

      <h2 class="mt-3">New book</h2>
      <%= form_with model: @book do |f| %>
        <div class="mb-2">
          <p>Title</p>
          <%= f.text_field :title, class: "form-control" %>
        </div>
        <div class="mb-3">
          <p>Opinion</p>
          <%= f.text_area :opinion, class: "form-control" %>
        </div>
          <%= f.submit "Create Book", class: "btn btn-success" %>
      <% end %>
    </div>


    <div class="col-8">
      <h2>Books</h2>
      <table class="table">
        <thead>
          <tr>
            <th>Title</th>
            <th>Opinion</th>
          </tr>
        </thead>
        <tbody>
          <% @books.each do |book| %>
            <tr>
              <td><%= book.title %></td>
              <td><%= book.opinion %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>