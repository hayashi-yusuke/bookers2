<div class="container mt-3">
  <div class="row">
    <%= render 'users/user_info' %>

    <div class="col-md-8 offset-md-1">
      <h2 style="border-bottom: 1px solid #ccc;">Books</h2>
      <table class="table table-hover">
        <thead style="border-bottom: 2px solid #ccc;">
          <tr>
            <th style="width: 20%;"></th>
            <th style="width: 40%;">Title</th>
            <th style="width: 40%;">Opinion</th>
            <th>コメント</th>
          </tr>
        </thead>
        <tbody>
          <% @books.each do |book| %>
            <tr>
              <td>
                <%= link_to user_path(book.user) do %>
                  <%= image_tag book.user.profile_image.attached? ? book.user.profile_image : "no_image.jpg", style: "width: 50px; height: 50px; object-fit: cover; border: 1px solid #ccc;" %>
                <% end %>
              </td>
              <td>
                <%= link_to book.title, book_path(book), style: "text-decoration: none;" %>
              </td>
              <td><%= book.body %></td>
              <td><%= book.book_comments.count %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <!-- 投稿数の統計 -->
      <h2 class="mt-3">投稿数の前日比・前週比</h2>

      <!-- 今日・前日・前日比 -->
      <table class="table table-bordered" style="width: 80%;">
        <thead>
          <tr>
            <th>今日の投稿数</th>
            <th>前日の投稿数</th>
            <th>前日比</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><%= @today_books_count %></td>
            <td><%= @yesterday_books_count %></td>
            <td><%= @today_yesterday_rate %></td>
          </tr>
        </tbody>
      </table>

      <!-- 間を開ける -->
      <div class="mt-4"></div>

      <!-- 今週・先週・先週比 -->
      <table class="table table-bordered" style="width: 80%;">
        <thead>
          <tr>
            <th>今週の投稿数</th>
            <th>先週の投稿数</th>
            <th>先週比</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><%= @this_week_books_count %></td>
            <td><%= @last_week_books_count %></td>
            <td><%= @this_last_week_rate %></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>