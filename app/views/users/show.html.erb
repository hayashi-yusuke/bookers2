<div class="container mt-3">
  <div class="row">
    <div class="col-3 offset-1">
      <h2>User info</h2>

      <% if @user.avatar.attached? %>
        <%= image_tag @user.avatar, class: "img-fluid", style: "width: 100px; height: 100px; object-fit: cover;" %>
      <% else %>
        <%= image_tag "no_image.jpg", class: "img-fluid", style: "width: 100px; height: 100px; object-fit: cover; border: 1px solid #ccc;" %>
      <% end %>

      <table class="table table-borderless">
        <tr class="border-top">
          <td><strong>name</strong></td>
          <td><strong><%= @user.name %></strong></td>
        </tr>
        <tr class="border-top">
          <td><strong>introduction</strong></td>
          <td><strong><%= @user.introduction %></strong></td>
        </tr>
      </table>

      <%= link_to edit_user_path(@user), class: "btn btn-outline-secondary", style: "width: 105%; margin-left: -2.5%;" do %>
        <i class="fa-solid fa-user-gear"></i>
      <% end %>

      <h2 class="mt-3">New book</h2>
      <%= form_with model: @book do |f| %>
        <div class="mb-2">
          <p>Title</p>
          <%= f.text_field :title, class: "form-control" %>
        </div>
        <div class="mb-3">
          <p>Opinion</p>
          <%= f.text_area :body, class: "form-control" %>
        </div>
          <%= f.submit "Create Book", class: "btn btn-success" %>
      <% end %>
    </div>


    <div class="col-6 offset-1">
      <h2 style="border-bottom: 1px solid #ccc;">Books</h2>
      <table class="table table-hover">
        <thead style="border-bottom: 2px solid #ccc;">
          <tr>
            <th></th>
            <th>Title</th>
            <th>Opinion</th>
          </tr>
        </thead>
        <tbody>
          <% @books.each do |book| %>
            <tr>
              <td>
                <%= link_to user_path(book.user) do %>
                  <%= image_tag book.user.avatar.attached? ? book.user.avatar : "no_image.jpg", style: "width: 50px; height: 50px; object-fit: cover;" %></td>
                <% end %>
              </td>
              <td>
                <%= link_to book.title, edit_book_path(book), style: "text-decoration: none;" %>
              </td>
              <td><%= book.body %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>