<div>
  <div>
    <h2>User info</h2>

    <img src="NO IMAGE" alt="プロフィール画像">

    <p>name</p>
    <p><%= @user.name %></p>
    
    <p>introduction</p>
    <p><%= @user.introduction %></p>

    <%= link_to edit_user_path(@user) do %>
      編集
    <% end %>

    <h2>New book</h2>
    <%= form_with model: @book do |f| %>
      <p>Title</p>
      <%= f.text_field :title %>
      <p>Opinion</p>
      <%= f.text_area :opinion %>
      <%= f.submit "Create Book" %>
    <% end %>
  </div>


  <div>
    <h2>Books</h2>
    <table>
      <tr>
        <th>Title</th>
        <th>Opinion</th>
      </tr>
      <% @books.each do |book| %>
        <tr>
          <td><%= book.title %></td>
          <td><%= book.opinion %></td>
        </tr>
      <% end %>
    </table>
  </div>

</div>