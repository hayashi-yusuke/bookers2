<div class="col-md-3">
  <% if @new_book.errors.any? %>
      <div class="alert alert-danger">
        <h5><%= @new_book.errors.count %> error occurred:</h5>
        <ul>
          <% @new_book.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
  <h2>User info</h2>

  <% if @user.profile_image.attached? %>
    <%= image_tag @user.profile_image, class: "img-fluid", style: "width: 100px; height: 100px; object-fit: cover;" %>
  <% else %>
    <%= image_tag "no_image.jpg", class: "img-fluid", style: "width: 100px; height: 100px; object-fit: cover; border: 1px solid #ccc;" %>
  <% end %>

  <table class="table table-borderless">
    <tr class="border-top">
      <td><strong>name</strong></td>
      <td><strong><%= @user.name %></strong></td>
    </tr>
    <tr class="border-top">
      <td><strong>introduction</strong></td>
      <td><strong><%= @user.introduction %></strong></td>
    </tr>
    <tr>
      <th>follows</th>
      <th><%= link_to @user.followings.count, user_followings_path(@user) %></th>
    </tr>
    <tr>
      <th>followers</th>
      <th><%= link_to @user.followers.count, user_followers_path(@user) %></th>
    </tr>
</table>
  </table>

  <div class="row">
    <% if Current.user != @user %>
      <td><%= render "relationships/btn", user: @user, options: { class: ""} %></td>
      <!-- 相互フォローのときだけDMボタンを表示 -->
      <% if Current.user.following?(@user) && @user.following?(Current.user) %>
        <%= link_to "DMを送る", user_messages_path(@user), class: "btn btn-outline-primary mt-2", style: "width: 100%;" %>
      <% end %>
    <% else %>
      <%= link_to edit_user_path(@user), class: "btn btn-outline-secondary", style: "width: 100%;" do %>
        <i class="fa-solid fa-user-gear"></i>
      <% end %>
    <% end %>
  </div>

  <h2 class="mt-3">New book</h2>
  <%= form_with model: @new_book do |f| %>

    <div class="mb-2">
      <p>Title</p>
      <%= f.text_field :title, class: "form-control" %>
    </div>
    <div class="mb-3">
      <p>Opinion</p>
      <%= f.text_area :body, class: "form-control" %>
    </div>
    <div class="mb-3">
      <p>評価</p>
      <div id="post_raty"></div>
    </div>

    <%= f.submit "Create Book", class: "btn", style: "background-color: #28a745; color: white;" %>
  <% end %>
</div>