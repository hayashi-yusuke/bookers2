<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Bookers2" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Bookers2">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <%# bootstrap%>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <%#. font-awesome%>
    <script src="https://kit.fontawesome.com/10dd81a308.js" crossorigin="anonymous"></script>
  
  </head>

  <body>
    <header>
      <nav class="navbar navbar-expand-lg navbar-dark" style="background-color: #343a40;" >
        <div class="container">
          <%= link_to root_path, class: "navbar-brand" do %>
            <span>Bookers</span>
          <% end %>

          <div class="collapse navbar-collapse", id="navbarNavDropdown">
            <ul class="navbar-nav ms-auto">
              <% if Current.user %>
                <li class="nav-item">
                  <%= link_to user_path(Current.user), class: "nav-link text-light" do %>
                    <i class="fa-solid fa-home"></i>Home
                  <% end %>
                </li>
                <li class="nav-item">
                  <%= link_to users_path, class: "nav-link text-light" do %>
                    <i class="fa-solid fa-users"></i> Users
                  <% end %>
                </li>
                <li>
                   <%= link_to books_path, class: "nav-link text-light" do %>
                <i class="fa-solid fa-book-open"></i> Books
                  <% end %>
                </li>
                <li>
                  <%= link_to session_path, data: { turbo_method: :delete }, class: "nav-link text-light" do %>
                    <i class="fa-solid fa-sign-out-alt"></i> Log out
                  <% end %>
                </li>

              <% else %>
                <li>
                  <%= link_to root_path, class: "nav-link text-light" do %>
                    <i class="fa-solid fa-home"></i> Home
                  <% end %>
                </li>
                <li>
                  <%= link_to homes_about_path, class: "nav-link text-light" do %>
                    <i class="fa-solid fa-link"></i> About
                  <% end %>
                </li>
                <li>
                  <%= link_to sign_up_path, class: "nav-link text-light" do %>
                    <i class="fa-solid fa-user-plus"></i> Sign up
                  <% end %>
                </li>
                <li>
                  <%= link_to new_session_path, class: "nav-link text-light" do %>
                    <i class="fa-solid fa-right-to-bracket"></i> Log in
                  <% end %>
                </li>
              <% end %>
            </ul>
          </div>
        </div>
      </nav>
    </header>

    <main class="">
      <%= flash[:notice] %>
      <%= flash[:alert] %>
      <%= yield %>

    </main>


    <footer>
      <div class="container mt-5">
        <div class="row">
          <div class="text-center">
            <p>CopyRight Infratop.inc</p>
          </div>
        </div>
      </div>
    </footer>
    
  </body>
</html>
