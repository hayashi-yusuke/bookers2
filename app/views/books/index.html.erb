<div class="container px-5 px-sm-0">
  <div class="row">
    <%= render 'users/user_info' %>

    <div class="col-6 offset-md-1">
      <h2>Books</h2>
      <table class="table table-hover">
        <thead>
          <tr>
            <th></th>
            <th>Title</th>
            <th>Opinion</th>
          </tr>
        </thead>
        <tbody>
          <% @books.each do |book| %>
            <tr>
              <td>
                <%= link_to user_path(book.user) do %>
                  <% if book.user.profile_image.attached? %>
                    <%= image_tag book.user.profile_image, style: "width: 50px; height: 50px; object-fit: cover;" %>
                  <% else %>
                    <%= image_tag "no_image.jpg", style: "width: 50px; height: 50px; object-fit: cover;" %>
                  <% end %>
                <% end %>
              </td>
              <td><%= link_to book.title, book_path(book), style: "text-decoration: none;" %></td>
              <td><%= book.body %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

  </div>
</div>