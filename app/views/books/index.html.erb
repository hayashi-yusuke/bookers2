<div class="container px-5 px-sm-0 mt-3">
  <div class="row">
    <%= render 'users/user_info' %>

    <div class="col-md-8 offset-md-1">
      <h2 style="border-bottom: 1px solid #ccc;">Books</h2>
      <table class="table table-hover">
        <thead style="border-bottom: 2px solid #ccc;">
          <tr>
            <th style="width: 80px;"></th>
            <th style="width: 210px;">Title</th>
            <th>Opinion</th>
            <th style="width: 80px;">いいね</th>
          </tr>
        </thead>
        <tbody>
          <% @books.each do |book| %>
            <tr>
              <td>
                <%= link_to user_path(book.user) do %>
                  <% if book.user.profile_image.attached? %>
                    <%= image_tag book.user.profile_image, style: "width: 80px; height: 80px; object-fit: cover; border: 1px solid #ccc;" %>
                  <% else %>
                    <%= image_tag "no_image.jpg", style: "width: 80px; height: 80px; object-fit: cover; border: 1px solid #ccc;" %>
                  <% end %>
                <% end %>
              </td>
              <td><%= link_to book.title, book_path(book), class: "text-decoration-none hover-underline" %></td>
              <td><%= book.body %></td>
                <td style="white-space: nowrap;">
                  <%= turbo_frame_tag dom_id(book, :favorite) do %>
                    <%= render 'favorites/favorite_btn', book: book %>
                  <% end %>
                </td>
              <td>
                <%= book.book_comments.count %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

  </div>
</div>