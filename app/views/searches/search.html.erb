<div class="container mt-3">
  <h2>検索結果</h2>

  <% if @model == "User" %>
    <% if @records.present? %>
      <% @records.each do |user| %>
        <div class="d-flex align-items-center mb-3">
          <%= link_to user_path(user) do %>
            <% if user.profile_image.attached? %>
              <%= image_tag user.profile_image, style: "width: 50px; height: 50px; object-fit: cover;" %>
            <% else %>
              <%= image_tag "no_image.jpg", style: "width: 50px; height: 50px; object-fit: cover;" %>
            <% end %>
          <% end %>
          <p class="ms-2 mb-0"><%= link_to user.name, user_path(user) %></p>
        </div>
      <% end %>
    <% else %>
      <p>ユーザーが見つかりませんでした</p>
    <% end %>

  <% elsif @model == "Book" %>
    <% if @records.present? %>
      <% @records.each do |book| %>
        <div class="mb-3">
          <p><%= link_to book.title, book_path(book) %></p>
          <p><%= book.body %></p>
        </div>
      <% end %>
    <% else %>
      <p>投稿が見つかりませんでした</p>
    <% end %>
  <% end %>
</div>