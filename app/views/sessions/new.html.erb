<div class="container mt-3">
  <div class="row justify-content-center">
    <div class="col-10">
      <h2>Log in</h2>
            
      <%= tag.div(flash[:alert], style: "color:red") if flash[:alert] %>
      <%= tag.div(flash[:notice], style: "color:green") if flash[:notice] %>

      <%= form_with url: session_path, method: :post do |f| %>

        <%# 名前でログイン %>
        <div class="field">
          <%= f.label :name %><br>
          <%= f.text_field :name, required: true, autofocus: true %>
        </div>
        <%# パスワード %>
        <div class="field">
          <%= f.label :password %><br>
          <%= f.password_field :password, required: true, 
          autocomplete: "current-password" %>
        </div>

        <div class="gap-2">
          <%= f.submit "Log in", class: "btn btn-primary btn-sm mt-2" %><br>
          <%= link_to "Sign up", new_user_path, class: "text-decoration-none" %>
        </div>

      <% end %>

      <%= link_to "Forgot password?", new_password_path, class: "text-decoration-none" %>
      
    </div>
  </div>
</div>