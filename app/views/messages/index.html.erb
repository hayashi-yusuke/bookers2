<div class="dm-container">

  <!-- サイドバー：DMしたことがある相手一覧 -->
  <div class="dm-sidebar">
    <h3>DM一覧</h3>
    <% @partners.each do |partner| %>
      <%= link_to partner.name, user_messages_path(partner) %>
    <% end %>
  </div>

  <!-- メインエリア：メッセージ表示 -->
  <div class="dm-main">

    <!-- メッセージ一覧 -->
    <div class="dm-messages">
      <% @messages.each do |message| %>
        <div class="dm-message">
          <!-- 送信者の名前 -->
          <span class="dm-sender"><%= message.sender.name %></span>
          <!-- メッセージ本文 -->
          <span class="dm-content"><%= message.content %></span>
        </div>
      <% end %>
    </div>

    <!-- メッセージ送信フォーム -->
    <%= form_with model: @message, url: user_messages_path(@other_user) do |f| %>

      <!-- エラーメッセージ表示 -->
      <% if @message.errors.any? %>
        <% @message.errors.full_messages.each do |msg| %>
          <p><%= msg %></p>
        <% end %>
      <% end %>

      <!-- 本文入力欄 -->
      <%= f.text_area :content, placeholder: "メッセージを入力（140文字まで）" %>

      <!-- 送信ボタン -->
      <%= f.submit "送信" %>

    <% end %>
  </div>

</div>